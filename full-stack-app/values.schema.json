{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "full-stack-app values",
  "type": "object",
  "properties": {
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "host": { "type": "string", "minLength": 1 }
      },
      "required": ["enabled", "host"]
    },
    "frontend": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "service": {
          "type": "object",
          "properties": { "port": { "type": "integer" } }
        }
      }
    },
    "backend": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "service": {
          "type": "object",
          "properties": { "port": { "type": "integer" } }
        }
      }
    },
    "database": {
      "type": "object",
      "properties": {
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "size": { "type": "string", "pattern": "^[0-9]+(Mi|Gi)$" }
          }
        }
      }
    }
  }
}
